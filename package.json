{
  "name": "my-v0-project",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20 <23"
  },
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "preinstall": "node scripts/check-node-version.mjs",
    "postinstall": "node scripts/postinstall-prisma-safe.mjs",
    "predev": "node scripts/check-node-version.mjs && node scripts/bootstrap-market-db.mjs",
    "prebuild": "node scripts/check-node-version.mjs && node scripts/validate-production-env.mjs && node scripts/bootstrap-market-db.mjs && node scripts/cleanup-next-processes.mjs --force",
    "prestart": "node scripts/check-node-version.mjs && node scripts/validate-production-env.mjs && node scripts/bootstrap-market-db.mjs",
    "build": "next build",
    "dev": "node scripts/dev-next.mjs",
    "dev:next": "node scripts/dev-next.mjs",
    "dev:reset": "node scripts/dev-reset.mjs --reset",
    "env:secret": "node scripts/generate-auth-secret.mjs",
    "env:validate:prod": "node scripts/validate-production-env.mjs",
    "seed:admin": "node scripts/seed-admin.mjs",
    "db:bootstrap": "node scripts/bootstrap-market-db.mjs",
    "e2e:live": "node scripts/e2e-live-flow.mjs",
    "lint": "next lint",
    "start": "next start",
    "prisma:generate": "prisma generate",
    "prisma:db:push": "prisma db push",
    "db:studio": "prisma studio",
    "prisma:generate:postgres": "prisma generate --schema prisma/postgres/schema.prisma",
    "prisma:migrate:dev:postgres": "prisma migrate dev --schema prisma/postgres/schema.prisma",
    "prisma:migrate:deploy:postgres": "prisma migrate deploy --schema prisma/postgres/schema.prisma",
    "prisma:studio:postgres": "prisma studio --schema prisma/postgres/schema.prisma"
  },
